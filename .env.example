# HMS Mobile App Environment
# Copy this file to .env and replace with your machine LAN IP.
# Example LAN IP: 192.168.1.10

# REST API base (must include /api/v1)
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:5000/api/v1

# Socket server base (without /api/v1)
EXPO_PUBLIC_SOCKET_URL=http://192.168.1.10:5000
